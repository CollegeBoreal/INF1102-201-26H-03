## 🎯 Objectif
Ce notebook analyse un fichier de logs web et affiche les IP les plus actives les URLs les plus visitées et les codes HTTP.

from collections import Counter
from datetime import datetime

file = "data/sample.log"

ips = []
urls = []
codes = []

with open(file, "r", encoding="utf-8") as f:
    for line in f:
        parts = line.split()
        if len(parts) > 7:
            ips.append(parts[0])
            urls.append(parts[5])
            codes.append(parts[7])

top_ips = Counter(ips).most_common(5)
top_urls = Counter(urls).most_common(5)
top_codes = Counter(codes).most_common()

print("✅ Fichier chargé avec succès")
print(f"📊 Nombre total de requêtes : {len(ips)}")
print(f"🌐 Nombre d'IP uniques : {len(set(ips))}")
print(f"📄 Nombre d'URLs uniques : {len(set(urls))}")

print("=" * 50)
print("  RAPPORT ANALYSE LOGS WEB")
print("=" * 50)
print(f"Date        : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
print(f"Fichier     : sample.log")
print(f"Requêtes    : {len(ips)}")
print("=" * 50)

print("\n🌐 TOP 5 IPs")
for ip, count in top_ips:
    print(f"{ip} : {count}")

print("\n📄 TOP 5 URLs")
for url, count in top_urls:
    print(f"{url} : {count}")

print("\n⚠️ Codes HTTP")
for code, count in top_codes:
    print(f"{code} : {count}")


import matplotlib.pyplot as plt

labels = [ip for ip, _ in top_ips]
values = [count for _, count in top_ips]

plt.figure(figsize=(8,5))
plt.bar(labels, values)
plt.title("Top 5 IPs")
plt.xlabel("Adresse IP")
plt.ylabel("Nombre de requêtes")
plt.show()

now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

with open("output/rapport.txt", "w", encoding="utf-8") as f:
    f.write("=" * 50 + "\n")
    f.write("  RAPPORT ANALYSE LOGS WEB\n")
    f.write("=" * 50 + "\n")
    f.write(f"Date        : {now}\n")
    f.write(f"Fichier     : sample.log\n")
    f.write(f"Requêtes    : {len(ips)}\n")
    f.write("=" * 50 + "\n\n")

    f.write("TOP 5 IPs\n")
    for ip, count in top_ips:
        f.write(f"{ip} : {count}\n")

    f.write("\nTOP 5 URLs\n")
    for url, count in top_urls:
        f.write(f"{url} : {count}\n")

    f.write("\nCodes HTTP\n")
    for code, count in top_codes:
        f.write(f"{code} : {count}\n")

print("✅ rapport.txt généré")


## ✅ Conclusion
Ce projet permet d'analyser automatiquement un fichier log web et de produire un rapport clair avec Python.
